# VIDEO profile (avatar + ConvoAI). Fill values from secure key source.
VIDEO_APP_ID=<APP_ID>
VIDEO_APP_CERTIFICATE=<APP_CERTIFICATE>

# LLM (OpenAI style)
VIDEO_ENABLE_MLLM=false
VIDEO_LLM_API_KEY=<OPENAI_API_KEY>
VIDEO_LLM_MODEL=gpt-4o-mini
VIDEO_LLM_URL=https://api.openai.com/v1/chat/completions

# TTS (ElevenLabs)
VIDEO_TTS_VENDOR=elevenlabs
VIDEO_TTS_KEY=<ELEVENLABS_API_KEY>
VIDEO_TTS_VOICE_ID=<ELEVENLABS_VOICE_ID>
VIDEO_ELEVENLABS_MODEL=eleven_flash_v2_5
VIDEO_TTS_SAMPLE_RATE=24000

# ASR / AIVAD
VIDEO_ASR_VENDOR=ares
VIDEO_ENABLE_AIVAD=true

# Avatar (Anam or HeyGen)
VIDEO_AVATAR_VENDOR=anam
VIDEO_AVATAR_API_KEY=<ANAM_API_KEY>
VIDEO_AVATAR_ID=<ANAM_AVATAR_ID>
VIDEO_HEYGEN_QUALITY=high

# Prompts (override in runtime if needed)
VIDEO_DEFAULT_GREETING=Welcome to Smart Onboard! I will quickly learn about your goals and level.
VIDEO_DEFAULT_PROMPT=You are Smart Onboard, a friendly intake agent for language learners. Keep replies under 25 words and always ask the next question promptly.
VIDEO_DEFAULT_FAILURE_MESSAGE=Sorry, something went wrong. Please try again.

# Debug
VIDEO_ENABLE_CURL_DUMP=true
