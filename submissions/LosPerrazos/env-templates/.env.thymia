# THYMIA profile (voice biomarkers, no avatar)
THYMIA_APP_ID=<APP_ID>
THYMIA_APP_CERTIFICATE=<APP_CERTIFICATE>

# LLM
THYMIA_ENABLE_MLLM=false
THYMIA_LLM_API_KEY=<OPENAI_API_KEY>
THYMIA_LLM_MODEL=gpt-4o-mini
THYMIA_LLM_URL=https://api.openai.com/v1/chat/completions

# TTS (choose vendor; here ElevenLabs)
THYMIA_TTS_VENDOR=elevenlabs
THYMIA_TTS_KEY=<ELEVENLABS_API_KEY>
THYMIA_TTS_VOICE_ID=<ELEVENLABS_VOICE_ID>
THYMIA_ELEVENLABS_MODEL=eleven_flash_v2_5
THYMIA_TTS_SAMPLE_RATE=24000

# ASR / AIVAD
THYMIA_ASR_VENDOR=ares
THYMIA_ENABLE_AIVAD=true

# Biomarkers
THYMIA_THYMIA_API_KEY=<THYMIA_API_KEY>

# Prompts
THYMIA_DEFAULT_GREETING=Hi! I’ll ask a few questions to tailor your lessons.
THYMIA_DEFAULT_PROMPT=You are Smart Onboard in voice-only mode. Keep replies under 20 words and collect onboarding data efficiently.

# Debug
THYMIA_ENABLE_CURL_DUMP=true
