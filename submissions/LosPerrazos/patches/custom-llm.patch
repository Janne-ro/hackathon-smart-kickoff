index cf7854c..8c97f5d 100644
--- a/node/conversation_store.js
+++ b/node/conversation_store.js
@@ -153,9 +153,29 @@ logger.info(
   `Conversation store initialized (max=${MAX_MESSAGES}, target=${TARGET_MESSAGES}, cleanup every ${CLEANUP_INTERVAL / 1000}s)`
 );
 
+/**
+ * Get all messages for a given channel across all userIds.
+ * Keys are formatted as "appId:userId:channel" — we match by prefix and suffix.
+ */
+function getMessagesByChannel(appId, channel) {
+  const prefix = `${appId}:`;
+  const suffix = `:${channel}`;
+  const allMessages = [];
+
+  for (const [key, conv] of Object.entries(conversations)) {
+    if (key.startsWith(prefix) && key.endsWith(suffix)) {
+      allMessages.push(...conv.messages);
+    }
+  }
+
+  allMessages.sort((a, b) => (a.timestamp || 0) - (b.timestamp || 0));
+  return allMessages;
+}
+
 module.exports = {
   getOrCreateConversation,
   saveMessage,
   getMessages,
+  getMessagesByChannel,
   cleanupOldConversations,
 };
